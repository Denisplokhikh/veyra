{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "checkJs": false,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "typeAcquisition": {
    "enable": true,
    "include": ["node"]
  },
  "include": [
    "apps/**/*.js",
    "packages/**/*.js",
    "examples/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
